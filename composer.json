{
  "name": "jacq-system/orm-model",
  "description": "Shared Doctrine ORM and services for JACQ projects",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "JACQ\\": "src/"
    },
    "autoload-dev": {
      "psr-4": {
        "JACQ\\Tests\\": "tests/"
      }
    }
  },
  "require": {
    "php": "^8.5",
    "ext-curl": "*",
    "ext-gd": "*",
    "ext-simplexml": "*",
    "doctrine/orm": "^3",
    "mjaschen/phpgeo": "^6",
    "phpoffice/phpspreadsheet": "^5",
    "symfony/http-client": "^8",
    "symfony/http-foundation": "^8",
    "doctrine/doctrine-bundle": "^3",
    "guzzlehttp/guzzle": "^7",
    "nyholm/psr7": "^1"
  },
  "config": {
    "platform": {
      "php": "8.5",
      "ext-gd": "7",
      "ext-curl": "1"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-doctrine": "^2.0",
    "symfony/var-exporter": "^7",
    "phpunit/phpunit": "^13.1",
    "friendsofphp/php-cs-fixer": "^3.95"
  }
}
